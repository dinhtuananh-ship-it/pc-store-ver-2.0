<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Nhập - PC STORE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card border-0 shadow-sm p-4 rounded-3 bg-white" style="width: 100%; max-width: 420px;">
            <div class="text-center mb-4">
                <h3 class="fw-bold text-primary"><i class="bi bi-cpu-fill"></i> PC STORE</h3>
                <p class="text-muted small">Đăng nhập tài khoản hệ thống khách hàng</p>
            </div>
            
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger py-2 text-center small"><%= error %></div>
            <% } %>

            <form action="/login" method="POST">
                <div class="mb-3">
                    <label class="form-label small fw-bold">Email hoặc Số điện thoại</label>
                    <input type="text" name="email" class="form-control" placeholder="Nhập email hoặc số điện thoại" required>
                </div>
                <div class="mb-3">
                    <label class="form-label small fw-bold">Mật khẩu</label>
                    <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu" required>
                </div>
                
                <div class="mb-4 d-flex justify-content-between align-items-center small">
                    <a href="/forgot-password" class="text-danger text-decoration-none fw-bold"><i class="bi bi-question-circle"></i> Quên mật khẩu?</a>
                    <a href="/register" class="text-primary text-decoration-none">Đăng ký tài khoản</a>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 fw-bold py-2">ĐĂNG NHẬP</button>
            </form>
        </div>
    </div>
</body>
</html>