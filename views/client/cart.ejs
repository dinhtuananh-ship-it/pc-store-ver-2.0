<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Giỏ Hàng - PC STORE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3 shadow-sm">
        <div class="container">
            <a class="navbar-brand text-warning fw-bold" href="/"><i class="bi bi-cpu-fill me-2"></i> PC STORE</a>
            <a href="/" class="btn btn-outline-warning btn-sm"><i class="bi bi-arrow-left"></i> Tiếp tục mua sắm</a>
        </div>
    </nav>

    <div class="container my-5">
        <h3 class="fw-bold mb-4"><i class="bi bi-cart-check-fill text-primary"></i> Giỏ Hàng Của Bạn</h3>
        
        <% if (cart && cart.length > 0) { %>
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-0">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th style="width: 150px;">Số lượng</th>
                                <th>Thành tiền</th>
                                <th>Xóa</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% cart.forEach(item => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="<%= item.image %>" width="60" class="rounded me-3 object-fit-cover" style="height: 60px;">
                                            <strong><%= item.name %></strong>
                                        </div>
                                    </td>
                                    <td class="text-danger fw-bold"><%= item.price.toLocaleString('vi-VN') %> đ</td>
                                    <td>
                                        <form action="/cart/update/<%= item.id %>" method="POST" class="d-flex align-items-center gap-1">
                                            <input type="number" name="quantity" class="form-control form-control-sm text-center fw-bold" value="<%= item.quantity %>" min="1" required style="max-width: 70px;">
                                            <button type="submit" class="btn btn-sm btn-primary" title="Cập nhật số lượng">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <td class="text-danger fw-bold"><%= (item.price * item.quantity).toLocaleString('vi-VN') %> đ</td>
                                    <td><a href="/cart/remove/<%= item.id %>" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></a></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white text-end py-4 pe-4">
                    <h4 class="mb-3">Tổng cộng: <span class="text-danger fw-bold fs-3"><%= totalAmount.toLocaleString('vi-VN') %> đ</span></h4>
                    <button type="button" class="btn btn-primary btn-lg fw-bold px-5" data-bs-toggle="modal" data-bs-target="#checkoutModal">
                        Tiến hành thanh toán <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
            </div>
        <% } else { %>
            <div class="text-center py-5 bg-white shadow-sm rounded-3">
                <i class="bi bi-cart-x text-muted" style="font-size: 5rem;"></i>
                <h5 class="mt-3 text-muted">Giỏ hàng trống</h5>
            </div>
        <% } %>
    </div>

    <div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Thông tin giao hàng & Thanh toán</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form action="/cart/checkout" method="POST">
                    <div class="modal-body p-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Họ và tên người nhận</label>
                            <input type="text" name="hoten" class="form-control" value="<%= user ? (user.FULLNAME || user.fullname) : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="text" name="sdt" class="form-control" value="<%= user ? (user.PHONE || user.phone) : '' %>" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                            <textarea name="diachi" class="form-control" rows="2" required><%= user ? (user.ADDRESS || user.address) : '' %></textarea>
                        </div>
                        <hr>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-success"><i class="bi bi-ticket-perforated"></i> Mã giảm giá (Nếu có)</label>
                            <input type="text" name="discountCode" class="form-control border-success" placeholder="Ví dụ: ABC (Giảm 10%)">
                        </div>
                    </div>
                    <div class="modal-footer bg-light">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                        <button type="submit" class="btn btn-success fw-bold px-4">Xác Nhận Thanh Toán</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>