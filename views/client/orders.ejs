<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Đơn Hàng Của Tôi - PC STORE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>body { background-color: #f8f9fa; }</style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand text-warning fw-bold" href="/"><i class="bi bi-cpu-fill me-2"></i> PC STORE</a>
            <a href="/" class="btn btn-outline-warning btn-sm"><i class="bi bi-house-door"></i> Về trang chủ</a>
        </div>
    </nav>

    <div class="container my-5">
        <h3 class="fw-bold mb-4 text-dark"><i class="bi bi-bag-check me-2 text-primary"></i> Đơn Hàng Của Tôi</h3>
        
        <div class="card border-0 shadow-sm rounded-3">
            <div class="card-body p-0">
                <% if (orders && orders.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th class="ps-4 py-3">STT</th>
                                    <th>Ngày đặt</th>
                                    <th>Người nhận & Địa chỉ</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% orders.forEach((o, i) => { %>
                                    <tr>
                                        <td class="ps-4 fw-bold text-primary">#<%= i + 1 %></td>
                                        <td><%= new Date(o.CREATED_AT).toLocaleDateString('vi-VN') %></td>
                                        <td>
                                            <strong><%= o.HOTEN_NGUOI_NHAN %></strong><br>
                                            <small class="text-muted"><%= o.SDT_NGUOI_NHAN %> | <%= o.DIA_CHI_NHAN %></small>
                                        </td>
                                        <td class="text-danger fw-bold"><%= o.TONG_TIEN.toLocaleString('vi-VN') %> đ</td>
                                        <td>
                                            <span class="badge <%= o.TRANG_THAI === 'Hoàn thành' ? 'bg-success' : (o.TRANG_THAI === 'Đang giao' ? 'bg-warning text-dark' : 'bg-secondary') %> px-3 py-2">
                                                <%= o.TRANG_THAI %>
                                            </span>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <div class="text-center py-5">
                        <i class="bi bi-receipt text-muted" style="font-size: 4rem;"></i>
                        <h5 class="text-muted mt-3">Bạn chưa có đơn hàng nào.</h5>
                        <a href="/" class="btn btn-primary mt-2 px-4">Mua sắm ngay</a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

</body>
</html>