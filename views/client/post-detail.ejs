<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title><%= post.TITLE %> - PC STORE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-3 shadow-sm">
        <div class="container"><a class="navbar-brand text-warning fw-bold" href="/"><i class="bi bi-cpu-fill me-2"></i> PC STORE</a></div>
    </nav>

    <div class="container my-5">
        <div class="row justify-content-center">
            <div class="col-lg-8 bg-white p-4 p-md-5 shadow-sm rounded-3">
                <a href="/" class="btn btn-outline-secondary btn-sm mb-4"><i class="bi bi-arrow-left"></i> Quay lại trang chủ</a>
                <h1 class="fw-bold text-dark mb-3"><%= post.TITLE %></h1>
                <p class="text-muted small mb-4"><i class="bi bi-calendar3"></i> Đăng ngày: <%= new Date(post.CREATED_AT).toLocaleDateString('vi-VN') %></p>
                <img src="<%= post.IMAGE_URL || post.image_url || 'https://images.unsplash.com/photo-1591488320449-011701bb6704?w=800' %>" class="w-100 rounded-3 mb-4" style="max-height: 400px; object-fit: cover;">
                <p class="fw-bold fs-5 text-secondary"><%= post.SUMMARY %></p>
                <hr class="my-4">
                <div class="content text-dark" style="line-height: 1.8; white-space: pre-line;">
                    <%= post.CONTENT || post.content %>
                </div>
            </div>
        </div>
    </div>
</body>
</html>