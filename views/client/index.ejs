<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PC STORE - Máy Tính & Phụ Kiện</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }
        .product-card { transition: all 0.3s; border: none; border-radius: 10px; }
        .product-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .product-img { height: 200px; object-fit: cover; cursor: pointer; }
        .clickable-title { color: #212529; text-decoration: none; }
        .clickable-title:hover { color: #0d6efd; text-decoration: underline; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top py-3 shadow-sm">
        <div class="container">
            <a class="navbar-brand text-warning fw-bold" href="/"><i class="bi bi-cpu-fill me-2"></i> PC STORE</a>
            <form class="d-flex mx-auto col-lg-5" action="/" method="GET">
                <div class="input-group">
                    <input type="text" name="search" class="form-control" placeholder="Tìm máy tính, linh kiện..." value="<%= typeof search !== 'undefined' ? search : '' %>">
                    <button class="btn btn-warning" type="submit"><i class="bi bi-search"></i></button>
                </div>
            </form>
            <div class="d-flex align-items-center gap-3">
                <a class="text-white position-relative fs-5 me-2" href="/cart">
                    <i class="bi bi-cart3"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span>
                </a>

                <% if (typeof user !== 'undefined' && user) { %>
                    <div class="dropdown">
                        <a class="nav-link dropdown-toggle text-warning fw-bold" href="#" role="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle"></i> <%= user.FULLNAME || user.fullname || 'Thành viên' %>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                            <% if (user.ROLE_ID == 1 || user.role_id == 1) { %>
                                <li><a class="dropdown-item p-2 fw-bold text-primary" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i>Trang quản trị</a></li>
                                <li><hr class="dropdown-divider"></li>
                            <% } %>
                            <li><a class="dropdown-item p-2" href="/cart"><i class="bi bi-bag-check me-2"></i>Giỏ hàng của tôi</a></li>
                            <li><a class="dropdown-item p-2 fw-bold text-success" href="/orders/history"><i class="bi bi-receipt me-2"></i>Theo dõi đơn hàng</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item p-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                <% } else { %>
                    <a class="btn btn-outline-light btn-sm fw-bold" href="/login">Đăng nhập</a>
                    <a class="btn btn-warning btn-sm fw-bold text-dark" href="/register">Đăng ký</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <div class="row">
            <div class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-header bg-primary text-white fw-bold py-3"><i class="bi bi-list"></i> DANH MỤC SẢN PHẨM</div>
                    <div class="list-group list-group-flush">
                        <a href="/" class="list-group-item list-group-item-action fw-bold text-primary">Tất cả sản phẩm</a>
                        <% if(typeof categories !== 'undefined' && categories) { %>
                            <% categories.forEach(cat => { %>
                                <a href="/?category=<%= cat.ID %>" class="list-group-item list-group-item-action"><%= cat.CATEGORY_NAME %></a>
                            <% }) %>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div class="row">
                    <% if(typeof products !== 'undefined' && products && products.length > 0) { %>
                        <% products.forEach(p => { %>
                            <div class="col-md-4 mb-4">
                                <div class="card h-100 product-card shadow-sm">
                                    <a href="/product/<%= p.ID %>">
                                        <img src="<%= p.IMAGE || p.image || 'https://images.unsplash.com/photo-1603302576837-37561b2e2302?w=500' %>" class="card-img-top product-img">
                                    </a>
                                    <div class="card-body d-flex flex-column p-3">
                                        <h6 class="text-muted small mb-1"><%= p.BRAND %></h6>
                                        <h5 class="card-title fw-bold text-truncate">
                                            <a href="/product/<%= p.ID %>" class="clickable-title"><%= p.PRODUCT_NAME %></a>
                                        </h5>
                                        <p class="text-danger fw-bold fs-5 mb-3"><%= p.PRICE ? p.PRICE.toLocaleString('vi-VN') : 0 %> đ</p>
                                        <form action="/cart/add" method="POST" class="mt-auto">
                                            <input type="hidden" name="productId" value="<%= p.ID %>">
                                            <button type="submit" class="btn btn-outline-primary w-100 fw-bold btn-sm"><i class="bi bi-cart-plus"></i> Thêm vào giỏ</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="col-12 text-center py-5 text-muted card border-0 shadow-sm"><p class="mb-0">Không tìm thấy sản phẩm nào.</p></div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <div class="container my-5 pt-4 border-top">
        <h4 class="fw-bold text-dark mb-4"><i class="bi bi-newspaper text-primary me-2"></i>Tin Tức Công Nghệ</h4>
        <div class="row">
            <% if(typeof posts !== 'undefined' && posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm border-0 rounded-3 overflow-hidden">
                            <a href="/post/<%= post.ID %>">
                                <img src="<%= post.IMAGE_URL || post.image_url || 'https://images.unsplash.com/photo-1591488320449-011701bb6704?w=500' %>" class="card-img-top" style="height: 180px; object-fit: cover;">
                            </a>
                            <div class="card-body">
                                <h5 class="card-title fw-bold">
                                    <a href="/post/<%= post.ID %>" class="clickable-title"><%= post.TITLE %></a>
                                </h5>
                                <p class="card-text text-secondary small"><%= post.SUMMARY %></p>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-4 mt-5"><p class="small mb-0">PC Tuấn Anh số 1 Long Biên</p></footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>