<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng Ký Thành Viên - PC STORE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .register-card { max-width: 460px; width: 100%; border: none; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
    </style>
</head>
<body>

    <div class="card register-card p-4 bg-white my-4">
        <div class="text-center mb-4">
            <h3 class="fw-bold text-primary">ĐĂNG KÝ KHÁCH HÀNG</h3>
            <p class="text-muted small">Tạo tài khoản để trải nghiệm mua sắm phụ kiện PC</p>
        </div>

        <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger py-2 small text-center" role="alert"><%= error %></div>
        <% } %>

        <form action="/register" method="POST">
            <div class="mb-2">
                <label class="form-label small fw-bold text-secondary">Họ và tên</label>
                <input type="text" name="fullname" class="form-control" placeholder="Ví dụ: Nguyễn Văn A" required>
            </div>

            <div class="mb-2">
                <label class="form-label small fw-bold text-secondary">Địa chỉ Email</label>
                <input type="email" name="email" class="form-control" placeholder="example@gmail.com" required>
            </div>

            <div class="mb-2">
                <label class="form-label small fw-bold text-secondary">Số điện thoại</label>
                <input type="text" name="phone" class="form-control" placeholder="Nhập số điện thoại" required>
            </div>

            <div class="mb-2">
                <label class="form-label small fw-bold text-secondary">Địa chỉ giao hàng</label>
                <input type="text" name="address" class="form-control" placeholder="Nhập địa chỉ của bạn" required>
            </div>

            <div class="mb-4">
                <label class="form-label small fw-bold text-secondary">Mật khẩu bảo mật</label>
                <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu ít nhất 6 ký tự" required>
            </div>

            <button type="submit" class="btn btn-primary w-100 fw-bold py-2 text-uppercase">Tạo Tài Khoản Mới</button>
        </form>

        <div class="text-center border-top pt-3 mt-3">
            <span class="small text-muted">Đã có tài khoản thành viên? <a href="/login" class="text-decoration-none fw-bold">Đăng nhập</a></span>
        </div>
    </div>

</body>
</html>