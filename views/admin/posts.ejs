<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Quản Lý Bài Viết - PC STORE</title>

    <!-- BOOTSTRAP -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- ICON -->
    <link rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>

<body class="bg-light">

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="bg-dark text-white p-3 d-flex flex-column justify-content-between"
            style="min-width:260px; max-width:260px; min-height:100vh;">

            <div>

                <h4 class="text-warning fw-bold text-center my-3">
                    <i class="bi bi-cpu-fill"></i>
                    PC STORE ADMIN
                </h4>

                <hr class="border-secondary">

                <ul class="nav nav-pills flex-column gap-2">

                    <li class="nav-item">
                        <a href="/admin/dashboard" class="nav-link text-white">
                            <i class="bi bi-speedometer2 me-2"></i>
                            Thống kê doanh thu
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/admin/products" class="nav-link text-white">
                            <i class="bi bi-box-seam me-2"></i>
                            Quản lý sản phẩm
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/admin/users" class="nav-link text-white">
                            <i class="bi bi-people me-2"></i>
                            Quản lý tài khoản
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/admin/orders" class="nav-link text-white">
                            <i class="bi bi-cart3 me-2"></i>
                            Quản lý đơn hàng
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/admin/posts" class="nav-link text-white active bg-primary">
                            <i class="bi bi-newspaper me-2"></i>
                            Quản lý bài viết
                        </a>
                    </li>

                </ul>

            </div>

            <div>

                <hr class="border-secondary">

                <a href="/logout" class="btn btn-danger w-100 fw-bold py-2">

                    <i class="bi bi-box-arrow-right"></i>
                    Đăng xuất

                </a>

            </div>

        </div>

        <!-- CONTENT -->
        <div class="flex-grow-1 p-4">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-4">

                <h3 class="fw-bold text-dark">

                    <i class="bi bi-newspaper text-primary"></i>
                    Quản Lý Bài Viết

                </h3>

                <button class="btn btn-success fw-bold"
                    data-bs-toggle="modal"
                    data-bs-target="#addPostModal">

                    <i class="bi bi-plus-circle-fill"></i>
                    Đăng bài viết mới

                </button>

            </div>

            <!-- TABLE -->
            <div class="card border-0 shadow-sm rounded-3">

                <div class="card-body p-0">

                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-dark">

                            <tr>

                                <th class="ps-3" style="width:80px;">
                                    Mã
                                </th>

                                <th style="width:250px;">
                                    Tiêu đề
                                </th>

                                <th>
                                    Tóm tắt nội dung
                                </th>

                                <th class="text-center" style="width:180px;">
                                    Hành động
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            <% posts.forEach(post => { %>

                                <% let postId = post.ID || post.id; %>

                                    <tr>

                                        <!-- ID -->
                                        <td class="ps-3 text-muted">
                                            #<%= postId %>
                                        </td>

                                        <!-- TITLE -->
                                        <td class="fw-bold text-primary">
                                            <%= post.TITLE || post.title %>
                                        </td>

                                        <!-- SUMMARY -->
                                        <td class="text-secondary text-truncate"
                                            style="max-width:450px;">

                                            <%= post.SUMMARY || post.summary %>

                                        </td>

                                        <!-- ACTION -->
                                        <td class="text-center">

                                            <!-- EDIT -->
                                            <button class="btn btn-sm btn-warning fw-bold me-1"
                                                data-bs-toggle="modal"
                                                data-bs-target="#editPostModal<%= postId %>">

                                                <i class="bi bi-pencil-square"></i>
                                                Sửa

                                            </button>

                                            <!-- DELETE -->
                                            <form action="/admin/posts/delete/<%= postId %>"
                                                method="POST"
                                                class="d-inline"
                                                onsubmit="return confirm('Bạn muốn gỡ bài viết này xuống?');">

                                                <button type="submit"
                                                    class="btn btn-sm btn-danger fw-bold">

                                                    <i class="bi bi-trash3-fill"></i>
                                                    Xóa

                                                </button>

                                            </form>

                                        </td>

                                    </tr>

                                    <% }) %>

                        </tbody>

                    </table>

                </div>

            </div>

            <!-- EDIT MODALS -->
            <% posts.forEach(post => { %>

                <% let postId = post.ID || post.id; %>

                    <div class="modal fade"
                        id="editPostModal<%= postId %>"
                        tabindex="-1"
                        aria-hidden="true">

                        <div class="modal-dialog modal-lg">

                            <form action="/admin/posts/edit/<%= postId %>"
                                method="POST"
                                class="modal-content">

                                <!-- HEADER -->
                                <div class="modal-header bg-warning text-dark">

                                    <h5 class="modal-title fw-bold">

                                        <i class="bi bi-pencil-square"></i>
                                        Sửa Bài Viết #<%= postId %>

                                    </h5>

                                    <button type="button"
                                        class="btn-close"
                                        data-bs-dismiss="modal">
                                    </button>

                                </div>

                                <!-- BODY -->
                                <div class="modal-body">

                                    <!-- TITLE -->
                                    <div class="mb-3">

                                        <label class="form-label fw-bold">
                                            Tiêu đề bài viết
                                        </label>

                                        <input type="text"
                                            name="title"
                                            class="form-control"
                                            value="<%= post.TITLE || post.title %>"
                                            required>

                                    </div>

                                    <!-- SUMMARY -->
                                    <div class="mb-3">

                                        <label class="form-label fw-bold">
                                            Nội dung / Tóm tắt
                                        </label>

                                        <textarea name="summary"
                                            class="form-control"
                                            rows="6"
                                            required><%= post.SUMMARY || post.summary %></textarea>

                                    </div>

                                </div>

                                <!-- FOOTER -->
                                <div class="modal-footer">

                                    <button type="button"
                                        class="btn btn-secondary"
                                        data-bs-dismiss="modal">

                                        Đóng

                                    </button>

                                    <button type="submit"
                                        class="btn btn-warning fw-bold">

                                        <i class="bi bi-check-circle-fill"></i>
                                        Cập nhật bài viết

                                    </button>

                                </div>

                            </form>

                        </div>

                    </div>

                    <% }) %>

        </div>

    </div>

    <!-- ADD POST MODAL -->
    <div class="modal fade"
        id="addPostModal"
        tabindex="-1"
        aria-hidden="true">

        <div class="modal-dialog modal-lg">

            <form action="/admin/posts/add"
                method="POST"
                class="modal-content">

                <!-- HEADER -->
                <div class="modal-header bg-success text-white">

                    <h5 class="modal-title fw-bold">

                        <i class="bi bi-file-earmark-plus"></i>
                        Soạn Bài Viết Mới

                    </h5>

                    <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                    </button>

                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <!-- TITLE -->
                    <div class="mb-3">

                        <label class="form-label fw-bold">
                            Tiêu đề tin tức
                        </label>

                        <input type="text"
                            name="title"
                            class="form-control"
                            placeholder="Nhập tiêu đề bài viết..."
                            required>

                    </div>

                    <!-- SUMMARY -->
                    <div class="mb-3">

                        <label class="form-label fw-bold">
                            Nội dung / Mô tả ngắn
                        </label>

                        <textarea name="summary"
                            class="form-control"
                            rows="6"
                            placeholder="Nhập nội dung bài viết..."
                            required></textarea>

                    </div>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">

                    <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">

                        Hủy

                    </button>

                    <button type="submit"
                        class="btn btn-success fw-bold">

                        <i class="bi bi-cloud-upload-fill"></i>
                        Đăng bài lên web

                    </button>

                </div>

            </form>

        </div>

    </div>

    <!-- BOOTSTRAP JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>