<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Thống Kê Doanh Thu - PC STORE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="d-flex">
        <div class="bg-dark text-white p-3 d-flex flex-column justify-content-between" style="min-width: 260px; max-width: 260px; min-height: 100vh;">
            <div>
                <h4 class="text-warning fw-bold text-center my-3"><i class="bi bi-cpu-fill"></i> PC STORE ADMIN</h4>
                <hr class="border-secondary">
                <ul class="nav nav-pills flex-column gap-2">
                    <li class="nav-item"><a href="/admin/dashboard" class="nav-link text-white active bg-primary"><i class="bi bi-speedometer2 me-2"></i> Thống kê doanh thu</a></li>
                    <li class="nav-item"><a href="/admin/products" class="nav-link text-white"><i class="bi bi-box-seam me-2"></i> Quản lý sản phẩm</a></li>
                    <li class="nav-item"><a href="/admin/users" class="nav-link text-white"><i class="bi bi-people me-2"></i> Quản lý tài khoản</a></li>
                    <li class="nav-item"><a href="/admin/orders" class="nav-link text-white"><i class="bi bi-cart3 me-2"></i> Quản lý đơn hàng</a></li>
                    <li class="nav-item"><a href="/admin/posts" class="nav-link text-white"><i class="bi bi-newspaper me-2"></i> Quản lý bài viết</a></li>
                </ul>
            </div>
            <div><hr class="border-secondary"><a href="/logout" class="btn btn-danger w-100 fw-bold py-2"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></div>
        </div>
        <div class="flex-grow-1 p-4">
            <h3 class="fw-bold mb-4 text-dark"><i class="bi bi-speedometer2 text-primary"></i> Tổng Quan Doanh Thu</h3>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm bg-success text-white p-4 rounded-3">
                        <h5>Doanh thu hôm nay</h5>
                        <h2 class="fw-bold m-0"><%= todayRevenue.toLocaleString('vi-VN') %> đ</h2>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm bg-primary text-white p-4 rounded-3">
                        <h5>Doanh thu tháng này</h5>
                        <h2 class="fw-bold m-0"><%= monthRevenue.toLocaleString('vi-VN') %> đ</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
</html>