<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quản Lý Tài Khoản - PC STORE</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">
    <div class="d-flex">
        <div class="bg-dark text-white p-3 d-flex flex-column justify-content-between" style="min-width: 260px; max-width: 260px; min-height: 100vh;">
            <div>
                <h4 class="text-warning fw-bold text-center my-3"><i class="bi bi-cpu-fill"></i> PC STORE ADMIN</h4>
                <hr class="border-secondary">
                <ul class="nav nav-pills flex-column gap-2">
                    <li class="nav-item"><a href="/admin/dashboard" class="nav-link text-white"><i class="bi bi-speedometer2 me-2"></i> Thống kê doanh thu</a></li>
                    <li class="nav-item"><a href="/admin/products" class="nav-link text-white"><i class="bi bi-box-seam me-2"></i> Quản lý sản phẩm</a></li>
                    <li class="nav-item"><a href="/admin/users" class="nav-link text-white active bg-primary"><i class="bi bi-people me-2"></i> Quản lý tài khoản</a></li>
                    <li class="nav-item"><a href="/admin/orders" class="nav-link text-white"><i class="bi bi-cart3 me-2"></i> Quản lý đơn hàng</a></li>
                    <li class="nav-item"><a href="/admin/posts" class="nav-link text-white"><i class="bi bi-newspaper me-2"></i> Quản lý bài viết</a></li>
                </ul>
            </div>
            <div><hr class="border-secondary"><a href="/logout" class="btn btn-danger w-100 fw-bold py-2"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a></div>
        </div>

        <div class="flex-grow-1 p-4">
            <h3 class="fw-bold mb-4 text-dark"><i class="bi bi-people text-primary"></i> Quản Lý Thành Viên Hệ Thống</h3>
            
            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th class="ps-3">Mã</th>
                                <th>Họ và tên</th>
                                <th>Email</th>
                                <th>Số điện thoại</th>
                                <th>Vai trò</th>
                                <th class="text-center">Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach(u => { %>
                                <% let uId = u.ID || u.id; %>
                                <tr>
                                    <td class="ps-3 text-muted">#<%= uId %></td>
                                    <td class="fw-bold"><%= u.FULLNAME || u.fullname %></td>
                                    <td><%= u.EMAIL || u.email %></td>
                                    <td><%= u.PHONE || u.phone %></td>
                                    <td>
                                        <span class="badge <%= Number(u.ROLE_ID || u.role_id) === 1 ? 'bg-danger' : 'bg-secondary' %>">
                                            <%= Number(u.ROLE_ID || u.role_id) === 1 ? 'Quản trị viên' : 'Khách hàng' %>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <% if (Number(uId) !== Number(user.ID || user.id)) { %>
                                            <form action="/admin/users/delete/<%= uId %>" method="POST" onsubmit="return confirm('Xác nhận xóa tài khoản thành viên này vĩnh viễn?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger fw-bold">
                                                    <i class="bi bi-person-x-fill"></i> Xóa tài khoản
                                                </button>
                                            </form>
                                        <% } else { %>
                                            <span class="text-muted small italic"><i class="bi bi-lock-fill"></i> Đang đăng nhập</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>